// This program converts a person's age from human years into dog years.

const myAge = 24; // Stores my current age in human years

let earlyYears = 10.5 * 2; // The first two human years count as 10.5 dog years each

let laterYears = myAge - 2; // Stores the remaining human years after the first two years

laterYears *= 4; // Each later human year counts as 4 dog years

let myAgeInDogYears = earlyYears + laterYears; // Combines early years and later years into total dog years

const myName = "Oliver".toLowerCase(); // Stores my name in lowercase

console.log(
  `My name is ${myName}. I am ${myAge} years old in human years, which is ${myAgeInDogYears} years old in dog years.`
);
