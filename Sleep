const getSleepHours = day => {
  day = day.toLowerCase();
  switch (day) {
    case "monday":
      return 8
      break;

    case "tuesday":
      return 7
      break;

    case "wednesday":
      return 6
      break;

    case "thursday":
      return 5
      break;

    case "friday":
      return 4
      break;

    case "saturday":
      return 3
      break;

    case "sunday":
      return 2
      break;
  } 
}

const getActualSleepHours = () => 
  getSleepHours("Monday") + 
  getSleepHours("Tuesday") +
  getSleepHours("Wednesday") +
  getSleepHours("Thursday") +
  getSleepHours("Friday") +
  getSleepHours("Saturday") +
  getSleepHours("Sunday"); 



const getIdealSleepHours = () => {
  let idealHours = 8;
  return idealHours * 7;

};

const calculateSleepDebt = () => {
  const actualSleepHours = getActualSleepHours();
  const idealSleepHours = getIdealSleepHours();

  if (actualSleepHours === idealSleepHours) {
    console.log("You get enough sleep");
  } else if (actualSleepHours > idealSleepHours) {
    console.log("You get too much sleep");
    console.log(actualSleepHours - idealSleepHours);
    console.log("You get this many hours extra sleep per week");
  } else if (actualSleepHours < idealSleepHours) {
    console.log("You do not get enough sleep");
    console.log(idealSleepHours - actualSleepHours);
    console.log("You need this many more hours of sleep per week");
  } else {
    console.log("error");
  }
}
calculateSleepDebt();
