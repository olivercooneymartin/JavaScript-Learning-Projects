// This program calculates whether a person is getting enough sleep over a week.

// Returns the number of sleep hours for a given day
const getSleepHours = (day) => {
  day = day.toLowerCase(); // Converts input to lowercase for consistency

  switch (day) {
    case "monday":
      return 8;

    case "tuesday":
      return 7;

    case "wednesday":
      return 6;

    case "thursday":
      return 5;

    case "friday":
      return 4;

    case "saturday":
      return 3;

    case "sunday":
      return 2;
  }
};

// Calculates the total actual sleep hours for the week
const getActualSleepHours = () =>
  getSleepHours("Monday") +
  getSleepHours("Tuesday") +
  getSleepHours("Wednesday") +
  getSleepHours("Thursday") +
  getSleepHours("Friday") +
  getSleepHours("Saturday") +
  getSleepHours("Sunday");

// Calculates the ideal sleep hours for the week
const getIdealSleepHours = () => {
  let idealHours = 8; // Ideal hours of sleep per night
  return idealHours * 7; // Total for the week
};

// Compares actual sleep to ideal sleep and logs the result
const calculateSleepDebt = () => {
  const actualSleepHours = getActualSleepHours(); // Total actual sleep
  const idealSleepHours = getIdealSleepHours(); // Total ideal sleep

  if (actualSleepHours === idealSleepHours) {
    console.log("You get enough sleep");
  } else if (actualSleepHours > idealSleepHours) {
    console.log("You get too much sleep");
    console.log(actualSleepHours - idealSleepHours); // Extra hours
    console.log("You get this many hours extra sleep per week");
  } else if (actualSleepHours < idealSleepHours) {
    console.log("You do not get enough sleep");
    console.log(idealSleepHours - actualSleepHours); // Missing hours
    console.log("You need this many more hours of sleep per week");
  } else {
    console.log("Error");
  }
};

// Runs the program
calculateSleepDebt();
